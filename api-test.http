# VISITOR PASS API - TEST FILE

### ==========================================
### 1. REGISTER ADMIN
### ==========================================
POST http://localhost:3000/api/auth/register
Content-Type: application/json

{
    "name": "Admin User",
    "email": "admin@visitor.com",
    "password": "admin123",
    "role": "admin",
    "department": "Management",
    "phone": "9876543210"
}


### ==========================================
### 2. REGISTER SECURITY
### ==========================================
POST http://localhost:3000/api/auth/register
Content-Type: application/json

{
    "name": "Security Guard",
    "email": "security@visitor.com",
    "password": "security123",
    "role": "security",
    "department": "Security",
    "phone": "9876543211"
}


### ==========================================
### 3. REGISTER EMPLOYEE
### ==========================================
POST http://localhost:3000/api/auth/register
Content-Type: application/json

{
    "name": "Naseem Ahamad",
    "email": "naseem@visitor.com",
    "password": "naseem123",
    "role": "employee",
    "department": "IT",
    "phone": "9876543212"
}


### ==========================================
### 4. LOGIN (Get Token)
### ==========================================
POST http://localhost:3000/api/auth/login
Content-Type: application/json

{
    "email": "admin@visitor.com",
    "password": "admin123"
}


### ==========================================
### 5. GET PROFILE (Paste token below)
### ==========================================
GET http://localhost:3000/api/auth/profile
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6IjY5OWI3YTVjNjkzNGU1MjQyNzI1ZjMyNSIsImlhdCI6MTc3MTc5NzU4MiwiZXhwIjoxNzcyNDAyMzgyfQ.LD50YHCJN-zd7xXLrVlubLx-L1dKqwqbrYSgf0hzM_o


### ==========================================
### 6. GET ALL USERS (Admin only)
### ==========================================
GET http://localhost:3000/api/auth/users
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6IjY5OWI3YTVjNjkzNGU1MjQyNzI1ZjMyNSIsImlhdCI6MTc3MTc5NzU4MiwiZXhwIjoxNzcyNDAyMzgyfQ.LD50YHCJN-zd7xXLrVlubLx-L1dKqwqbrYSgf0hzM_o


